{
  "appId": "com.henalytics.app",
  "appName": "Henalytics",
  "webDir": "dist",
  "plugins": {
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#F4EDE0",
      "overlaysWebView": true
    },
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "launchFadeOutDuration": 300,
      "backgroundColor": "#F4EDE0",
      "iosSpinnerStyle": "small",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    }
  },
  "server": {
    "iosScheme": "https",
    "androidScheme": "https"
  }
}
