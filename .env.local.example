# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored so your keys never end up on GitHub.

# ----- Frontend (Supabase, used by browser) -----
# Get these from your Supabase project's Settings → Data API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ----- Backend (Resend, used by /api/send-email serverless function) -----
# Get this from https://resend.com/api-keys
# This key is SECRET and never gets exposed to the browser.
RESEND_API_KEY=re_your_resend_api_key

# Optional: change the From address (default: onboarding@resend.dev)
# Use your own verified domain once you've set one up in Resend.
EMAIL_FROM=Henalytics <onboarding@resend.dev>

# Optional: change where feedback and signup notifs go (default: slowbuildacres@gmail.com)
OWNER_EMAIL=slowbuildacres@gmail.com
